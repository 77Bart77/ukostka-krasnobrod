---
interface Props {
	lang?: 'pl' | 'en';
}

const { lang = 'pl' } = Astro.props;

const content = {
	pl: {
		message:
			'Używamy Google Analytics do anonimowych statystyk odwiedzin. Możesz zaakceptować analitykę albo korzystać ze strony bez niej.',
		accept: 'Akceptuję',
		reject: 'Odrzucam',
	},
	en: {
		message:
			'We use Google Analytics for anonymous visit statistics. You can accept analytics or use the website without it.',
		accept: 'Accept',
		reject: 'Reject',
	},
};

const t = content[lang];
---

<div
	id="analytics-consent"
	class="fixed inset-x-4 bottom-4 z-50 hidden rounded-lg border border-[#d8c4a2] bg-white p-4 shadow-lg md:left-auto md:max-w-md"
>
	<p class="text-sm leading-6 text-[#3f3528]">
		{t.message}
	</p>

	<div class="mt-4 flex gap-3">
		<button
			id="analytics-accept"
			type="button"
			class="rounded-md bg-[#173b2f] px-4 py-2 text-sm font-semibold text-white"
		>
			{t.accept}
		</button>

		<button
			id="analytics-reject"
			type="button"
			class="rounded-md border border-[#d8c4a2] px-4 py-2 text-sm font-semibold text-[#3f3528]"
		>
			{t.reject}
		</button>
	</div>
</div>

<script>
	const measurementId = 'G-4NW2E895Q3';
	const consentKey = 'ukostka_analytics_consent';

	function loadGoogleAnalytics() {
		if (document.documentElement.dataset.analyticsLoaded === 'true') {
			return;
		}

		document.documentElement.dataset.analyticsLoaded = 'true';

		const script = document.createElement('script');
		script.async = true;
		script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
		document.head.appendChild(script);

		window.dataLayer = window.dataLayer || [];
		window.gtag = function gtag() {
			window.dataLayer.push(arguments);
		};

		window.gtag('js', new Date());
		window.gtag('config', measurementId);
	}

	const savedConsent = localStorage.getItem(consentKey);
	const banner = document.getElementById('analytics-consent');
	const acceptButton = document.getElementById('analytics-accept');
	const rejectButton = document.getElementById('analytics-reject');

	if (savedConsent === 'accepted') {
		loadGoogleAnalytics();
	}

	if (!savedConsent && banner) {
		banner.classList.remove('hidden');
	}

	acceptButton?.addEventListener('click', () => {
		localStorage.setItem(consentKey, 'accepted');
		banner?.classList.add('hidden');
		loadGoogleAnalytics();
	});

	rejectButton?.addEventListener('click', () => {
		localStorage.setItem(consentKey, 'rejected');
		banner?.classList.add('hidden');
	});
</script>