---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import AnalyticsConsent from '../components/AnalyticsConsent.astro';

interface Props {
	title?: string;
	description?: string;
	lang?: 'pl' | 'en';
	langHref?: string;
}

const {
	title = 'U Kostka | Pokoje nad zalewem w Krasnobrodzie',
	description = 'Kameralne pokoje 50 metrów od zalewu w Krasnobrodzie. Spokojny pobyt blisko wody, lasu i Roztocza.',
	lang = 'pl',
	langHref,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>{title}</title>
	</head>
	<body class="bg-[#f7f1e8] text-[#173b2f] antialiased">
		<Navbar lang={lang} langHref={langHref} />
<slot />
	<Footer lang={lang} />
	<AnalyticsConsent lang={lang} />

<script>
	import '../scripts/alpine.js';
</script>
	</body>
</html>
